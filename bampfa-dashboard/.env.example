# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Anthropic API key — required for AI Insights page
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Tesitura API credentials (for live data integration)
# TESITURA_API_URL=https://your-instance.tesitura.com/api/
# TESITURA_USERNAME=your_username
# TESITURA_PASSWORD=your_password

# Optional: Google Analytics 4 credentials
# GA4_PROPERTY_ID=your_property_id
# GA4_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# --- Reddit (PRAW) — Public Sentiment page ---
# Create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=bampfa-dashboard/1.0

# --- NewsAPI.org — Public Sentiment page ---
# Free tier: ~1 month history, 100 requests/day
# Register at https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key

# --- Google Places API — Public Sentiment page ---
# Enable "Places API" in Google Cloud Console
# Note: Places API returns at most 5 reviews per place result (platform limitation)
# For larger review datasets use Google Business Profile export instead
GOOGLE_PLACES_API_KEY=your_google_places_key
